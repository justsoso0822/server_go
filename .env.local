# 应用名称，用于 Docker 容器命名
APP_NAME=server-go

# 应用版本号
APP_VERSION=1.0.0

# 控制接口访问令牌，用于管理接口鉴权
# 生产环境务必修改此值
APP_CONTROL_TOKEN=local-dev-token-2026

# GoFrame 配置文件名称
# 容器内使用 config.local.yaml
GF_GCFG_FILE=config.local.yaml

# 镜像来源：local=本地构建, remote=云端拉取
# 本地环境默认使用本地构建的镜像
IMAGE_SOURCE=local

# 网关对外暴露的端口
# 应用通过 Traefik 网关访问
HOST_GATEWAY_PORT=17001

# Traefik 管理面板端口
# 仅用于本地调试，生产环境不要对外开放
TRAEFIK_DASHBOARD_PORT=18080

# Traefik 访问日志格式
# json 格式便于日志采集和分析
TRAEFIK_ACCESSLOG_FORMAT=common