# 应用名称，用于 Docker 容器命名
APP_NAME=server-go

# 应用版本号
APP_VERSION=1.0.0

# GoFrame 配置文件名称
# 容器内使用 config.production.yaml
GF_GCFG_FILE=config.production.yaml

# 镜像来源：local=本地构建, remote=云端拉取
# 生产环境默认从云端拉取镜像
IMAGE_SOURCE=remote

# Docker 镜像地址
# 从腾讯云镜像仓库拉取
APP_IMAGE=ccr.ccs.tencentyun.com/justsoso-production/server-go:latest

# 网关对外暴露的端口
HOST_GATEWAY_PORT=7001

# Traefik 管理面板（生产环境必须关闭）
TRAEFIK_API_ENABLED=false
TRAEFIK_DASHBOARD_ENABLED=false

# Traefik 访问日志格式
TRAEFIK_ACCESSLOG_FORMAT=json