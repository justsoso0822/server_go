# ==============================================================================
# 测试环境配置
# 用于 go run cmd/deploy/main.go deploy test version=vX.Y.Z
# ==============================================================================

# 应用名称，用于 Docker 容器命名（同时作为容器名前缀和网络名）
APP_NAME=server-go

# 镜像仓库地址（腾讯云容器镜像服务）
IMAGE_REGISTRY=ccr.ccs.tencentyun.com/justsoso-test
# 镜像名称，与仓库地址拼接为完整引用
IMAGE_NAME=server-go

# 应用版本号（测试环境必须通过 version=vX.Y.Z 显式指定）
APP_VERSION=1.0.0

# GoFrame 配置文件名称（容器内使用 config.test.yaml）
GF_GCFG_FILE=config.test.yaml

# 镜像来源：local=本地构建, remote=云端拉取
# 测试环境从云端拉取已推送的镜像
IMAGE_SOURCE=remote

# Docker 镜像地址（部署时由脚本通过临时 env 文件覆盖为实际版本）
APP_IMAGE=ccr.ccs.tencentyun.com/justsoso-test/server-go:latest

# 网关对外暴露的宿主机端口
HOST_GATEWAY_PORT=7001

# Traefik 容器内监听端口（entrypoint）
GATEWAY_INTERNAL_PORT=7001
# 应用容器内 HTTP 服务端口
APP_INTERNAL_PORT=7001

# 发布控制参数
# 新容器健康检查超时（秒），超时则回滚
DEPLOY_HEALTH_TIMEOUT_SECONDS=60
# 切流确认超时（秒），在此时间内需连续确认流量已切换
DEPLOY_CUTOVER_TIMEOUT_SECONDS=30
# 连续命中新颜色的次数，达到后视为切流成功
DEPLOY_CUTOVER_CONFIRMATIONS=9
# 旧容器排水超时（秒），等待存量请求处理完毕
DEPLOY_DRAIN_TIMEOUT_SECONDS=15
# 本地保留的历史镜像数量，超出部分自动清理
DEPLOY_KEEP_IMAGES=10

# Traefik 管理面板（测试环境默认关闭，需要调试时可开启）
TRAEFIK_API_ENABLED=false
TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_DASHBOARD_PORT=18080

# Traefik 访问日志格式（json 便于日志采集和分析）
TRAEFIK_ACCESSLOG_FORMAT=json