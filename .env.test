# 应用名称，用于 Docker 容器命名
APP_NAME=server-go

# 应用版本号
APP_VERSION=1.0.0

# 控制接口访问令牌，用于管理接口鉴权
# 测试环境请修改此值
APP_CONTROL_TOKEN=PLEASE_CHANGE_ME_TEST

# GoFrame 配置文件名称
# 容器内使用 config.test.yaml
GF_GCFG_FILE=config.test.yaml

# 镜像来源：local=本地构建, remote=云端拉取
# 测试环境默认从云端拉取镜像
IMAGE_SOURCE=remote

# Docker 镜像地址
# 从腾讯云镜像仓库拉取
APP_IMAGE=ccr.ccs.tencentyun.com/justsoso-test/server-go:latest

# 网关对外暴露的端口
HOST_GATEWAY_PORT=7001

# Traefik 管理面板端口
# 生产环境不要对外开放此端口
TRAEFIK_DASHBOARD_PORT=18080

# Traefik 访问日志格式
TRAEFIK_ACCESSLOG_FORMAT=json