# 应用名称，用于 Docker 容器命名
APP_NAME=server-go

# 镜像仓库与名称
IMAGE_REGISTRY=ccr.ccs.tencentyun.com/justsoso-test
IMAGE_NAME=server-go

# 应用版本号
APP_VERSION=1.0.0

# GoFrame 配置文件名称
# 容器内使用 config.test.yaml
GF_GCFG_FILE=config.test.yaml

# 镜像来源：local=本地构建, remote=云端拉取
# 测试环境默认从云端拉取镜像
IMAGE_SOURCE=remote

# Docker 镜像地址
# 从腾讯云镜像仓库拉取
APP_IMAGE=ccr.ccs.tencentyun.com/justsoso-test/server-go:latest

# 网关对外暴露的端口
HOST_GATEWAY_PORT=7001

# 容器内部端口
GATEWAY_INTERNAL_PORT=7001
APP_INTERNAL_PORT=7001

# 发布控制参数
DEPLOY_HEALTH_TIMEOUT_SECONDS=60
DEPLOY_CUTOVER_TIMEOUT_SECONDS=30
DEPLOY_CUTOVER_CONFIRMATIONS=9
DEPLOY_DRAIN_TIMEOUT_SECONDS=15
DEPLOY_KEEP_IMAGES=10

# Traefik 管理面板（测试环境可选开启）
TRAEFIK_API_ENABLED=false
TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_DASHBOARD_PORT=18080

# Traefik 访问日志格式
TRAEFIK_ACCESSLOG_FORMAT=json