{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch server_go",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/main.go",
      "cwd": "${workspaceFolder}",
      "env": {
        "GO111MODULE": "on"
      }
    },
    {
      "name": "Debug scratch main",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/scratch/main.go",
      "cwd": "${workspaceFolder}",
      "env": {
        "GO111MODULE": "on"
      }
    }
  ]
}