# Git 相关
.git/
.gitattributes

# IDE / 工具配置
.claude/
.cursor/
hack/

# 环境变量文件（敏感信息，不需要进入镜像）
.env.*

# 日志文件
stdout/
*.log

# 操作系统垃圾文件
Thumbs.db
.DS_Store

# 配置文件（运行时通过 volume 挂载）
manifest/config/

# Docker 清单文件（镜像构建时不需要）
manifest/docker/

# 仅开发阶段使用的命令代码（不是主程序二进制入口）
cmd/

# 构建与版本控制元数据
.gitignore
Makefile

# 文档
*.md